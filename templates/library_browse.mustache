			<div style="flex-shrink: 0; padding: 32px 32px 16px 32px; background: #f9fafb;">
				<!-- Search Bar -->
				<div style="margin-bottom: 24px;">
					<div class="skeleton-bar" style="width: 100%; max-width: 512px; height: 42px; border-radius: 8px;"></div>
				</div>

				<!-- Filters -->
				<div style="display: flex; gap: 12px; flex-wrap: wrap;">
