<main id="library-browse-root" class="local-reblibrary-library-browse"
      data-resources='{{{resources_json}}}'
      data-levels='{{{levels_json}}}'
      data-sublevels='{{{sublevels_json}}}'
      data-classes='{{{classes_json}}}'
