	<style>
		.skeleton-bar {
			background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
			background-size: 200% 100%;
			animation: skeleton-loading 1.5s ease-in-out infinite;
			border-radius: 4px;
		}
		@keyframes skeleton-loading {
			0% { background-position: 200% 0; }
			100% { background-position: -200% 0; }
		}
	</style>
	<div class="loading-skeleton" style="display: flex; height: 100vh; overflow: hidden; background: white;">
		<!-- Sidebar Skeleton -->
		<aside style="width: 224px; background: #f9fafb; border-right: 1px solid #e5e7eb; padding: 24px 16px 24px 0; flex-shrink: 0;">
			<!-- Library Menu Section -->
			<div style="margin-bottom: 32px;">
				<div class="skeleton-bar" style="width: 80px; height: 10px; margin-bottom: 16px; margin-left: 12px;"></div>
				<div style="padding: 0 12px;">
					<div class="skeleton-bar" style="width: 100%; height: 36px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 36px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 36px; border-radius: 4px;"></div>
				</div>
			</div>

			<!-- Admin Menu Section -->
			<div>
				<div class="skeleton-bar" style="width: 75px; height: 10px; margin-bottom: 16px; margin-left: 12px;"></div>
				<div style="padding: 0 12px;">
