					<div class="skeleton-bar" style="width: 110px; height: 40px; border-radius: 9999px;"></div>
					<div class="skeleton-bar" style="width: 130px; height: 40px; border-radius: 9999px;"></div>
				</div>
			</div>

			<!-- Scrollable Content: Books Sections -->
			<div style="flex: 1; overflow-y: auto; padding: 0 32px 32px 32px;">
				<!-- First Class Section -->
				<div style="margin-bottom: 32px;">
