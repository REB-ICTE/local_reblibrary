{{!
    @template local_reblibrary/admin_page

    REB Library administration page template with tabbed interface.

    Context variables required for this template:
    * sidebar - Sidebar navigation data with admin menu
    * active_tab - Currently active tab
    * stats - Dashboard statistics
    * edu_levels, edu_sublevels, classes, sections - Education structure data
    * authors, resources, categories - Content data
}}

<div class="reblibrary-layout">
    {{! Left Sidebar Navigation }}
    <aside class="reblibrary-sidebar">
        {{! Admin Menu Section }}
        <div class="sidebar-section">
            <h6 class="sidebar-heading">{{sidebar.admin_menu_heading}}</h6>
            <ul class="sidebar-menu">
                {{#sidebar.admin_menu_items}}
                <li class="sidebar-item {{#active}}active{{/active}}">
                    <a href="{{url}}">
                        <i class="{{icon}}"></i>
                        <span>{{name}}</span>
                    </a>
                </li>
                {{/sidebar.admin_menu_items}}
            </ul>
        </div>

        {{! Library Menu Section }}
        <div class="sidebar-section">
            <h6 class="sidebar-heading">{{sidebar.library_menu_heading}}</h6>
            <ul class="sidebar-menu">
                {{#sidebar.library_menu_items}}
                <li class="sidebar-item {{#active}}active{{/active}}">
                    <a href="{{url}}">
                        <i class="{{icon}}"></i>
                        <span>{{name}}</span>
                    </a>
                </li>
                {{/sidebar.library_menu_items}}
            </ul>
        </div>
    </aside>

    {{! Main Content Area }}
    <main class="reblibrary-main">
        {{! Dashboard Tab }}
        {{#tab_dashboard}}
        <section class="admin-section">
            <h2 class="section-title">Dashboard Overview</h2>

            <div class="row mt-4">
                <div class="col-md-3 mb-3">
                    <div class="card stats-card">
                        <div class="card-body">
                            <div class="stats-icon"><i class="fa fa-book"></i></div>
                            <h3 class="stats-number">{{stats.total_resources}}</h3>
                            <p class="stats-label">Total Resources</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card stats-card">
                        <div class="card-body">
                            <div class="stats-icon"><i class="fa fa-user-edit"></i></div>
                            <h3 class="stats-number">{{stats.total_authors}}</h3>
                            <p class="stats-label">Authors</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card stats-card">
                        <div class="card-body">
                            <div class="stats-icon"><i class="fa fa-tags"></i></div>
                            <h3 class="stats-number">{{stats.total_categories}}</h3>
                            <p class="stats-label">Categories</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card stats-card">
                        <div class="card-body">
                            <div class="stats-icon"><i class="fa fa-graduation-cap"></i></div>
                            <h3 class="stats-number">{{stats.total_classes}}</h3>
                            <p class="stats-label">Classes</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <h5 class="alert-heading">Welcome to REB Library Administration</h5>
                <p>Use the sidebar menu to manage education structure, resources, categories, and assignments.</p>
            </div>
        </section>
        {{/tab_dashboard}}

        {{! Education Structure Tab }}
        {{#tab_education}}
        <section class="admin-section">
            <h2 class="section-title">Education Structure Management</h2>

            {{! Subtabs for education structure }}
            <ul class="nav nav-tabs mt-4" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#edu-levels-tab" type="button">Education Levels</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#edu-sublevels-tab" type="button">Sublevels</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#classes-tab" type="button">Classes</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#sections-tab" type="button">Sections (A-Level)</button>
                </li>
            </ul>

            <div class="tab-content mt-3">
                {{! Education Levels }}
                <div class="tab-pane fade show active" id="edu-levels-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Education Levels</h4>
                        <a href="admin_edu_levels.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Level</a>
                    </div>
                    {{#has_edu_levels}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Level Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#edu_levels}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{level_name}}</td>
                                <td>
                                    <a href="admin_edu_levels.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_edu_levels.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/edu_levels}}
                        </tbody>
                    </table>
                    {{/has_edu_levels}}
                    {{^has_edu_levels}}
                    <div class="alert alert-warning">No education levels defined yet. Click "Add Level" to create one.</div>
                    {{/has_edu_levels}}
                </div>

                {{! Sublevels }}
                <div class="tab-pane fade" id="edu-sublevels-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Education Sublevels</h4>
                        <a href="admin_edu_sublevels.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Sublevel</a>
                    </div>
                    {{#has_edu_sublevels}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Sublevel Name</th>
                                <th>Level ID</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#edu_sublevels}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{sublevel_name}}</td>
                                <td>{{level_id}}</td>
                                <td>
                                    <a href="admin_edu_sublevels.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_edu_sublevels.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/edu_sublevels}}
                        </tbody>
                    </table>
                    {{/has_edu_sublevels}}
                    {{^has_edu_sublevels}}
                    <div class="alert alert-warning">No sublevels defined yet. Click "Add Sublevel" to create one.</div>
                    {{/has_edu_sublevels}}
                </div>

                {{! Classes }}
                <div class="tab-pane fade" id="classes-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Classes</h4>
                        <a href="admin_classes.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Class</a>
                    </div>
                    {{#has_classes}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Class Name</th>
                                <th>Class Code</th>
                                <th>Sublevel ID</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#classes}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{class_name}}</td>
                                <td><span class="badge bg-info">{{class_code}}</span></td>
                                <td>{{sublevel_id}}</td>
                                <td>
                                    <a href="admin_classes.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_classes.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/classes}}
                        </tbody>
                    </table>
                    {{/has_classes}}
                    {{^has_classes}}
                    <div class="alert alert-warning">No classes defined yet. Click "Add Class" to create one.</div>
                    {{/has_classes}}
                </div>

                {{! Sections (A-Level) }}
                <div class="tab-pane fade" id="sections-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Sections (A-Level Combinations)</h4>
                        <a href="admin_sections.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Section</a>
                    </div>
                    {{#has_sections}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Section Name</th>
                                <th>Section Code</th>
                                <th>Sublevel ID</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#sections}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{section_name}}</td>
                                <td><span class="badge bg-success">{{section_code}}</span></td>
                                <td>{{sublevel_id}}</td>
                                <td>
                                    <a href="admin_sections.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_sections.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/sections}}
                        </tbody>
                    </table>
                    {{/has_sections}}
                    {{^has_sections}}
                    <div class="alert alert-warning">No sections defined yet. Click "Add Section" to create one.</div>
                    {{/has_sections}}
                </div>
            </div>
        </section>
        {{/tab_education}}

        {{! Resources Tab }}
        {{#tab_resources}}
        <section class="admin-section">
            <h2 class="section-title">Resource Management</h2>

            {{! Subtabs for resources }}
            <ul class="nav nav-tabs mt-4" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#resources-tab" type="button">Resources</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#authors-tab" type="button">Authors</button>
                </li>
            </ul>

            <div class="tab-content mt-3">
                {{! Resources }}
                <div class="tab-pane fade show active" id="resources-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Resources</h4>
                        <a href="admin_resources.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Resource</a>
                    </div>
                    {{#has_resources}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>ISBN</th>
                                <th>Author ID</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#resources}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{title}}</td>
                                <td>{{isbn}}</td>
                                <td>{{author_id}}</td>
                                <td>{{created_at}}</td>
                                <td>
                                    <a href="admin_resources.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_resources.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/resources}}
                        </tbody>
                    </table>
                    {{/has_resources}}
                    {{^has_resources}}
                    <div class="alert alert-warning">No resources defined yet. Click "Add Resource" to create one.</div>
                    {{/has_resources}}
                </div>

                {{! Authors }}
                <div class="tab-pane fade" id="authors-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Authors</h4>
                        <a href="admin_authors.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Author</a>
                    </div>
                    {{#has_authors}}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#authors}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{first_name}}</td>
                                <td>{{last_name}}</td>
                                <td>
                                    <a href="admin_authors.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                                    <a href="admin_authors.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                            {{/authors}}
                        </tbody>
                    </table>
                    {{/has_authors}}
                    {{^has_authors}}
                    <div class="alert alert-warning">No authors defined yet. Click "Add Author" to create one.</div>
                    {{/has_authors}}
                </div>
            </div>
        </section>
        {{/tab_resources}}

        {{! Categories Tab }}
        {{#tab_categories}}
        <section class="admin-section">
            <h2 class="section-title">Category Management</h2>

            <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
                <h4>Categories</h4>
                <a href="admin_categories.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Category</a>
            </div>
            {{#has_categories}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Category Name</th>
                        <th>Parent Category ID</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#categories}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{category_name}}</td>
                        <td>{{parent_category_id}}</td>
                        <td>{{description}}</td>
                        <td>
                            <a href="admin_categories.php?action=edit&id={{id}}" class="btn btn-sm btn-warning"><i class="fa fa-edit"></i> Edit</a>
                            <a href="admin_categories.php?action=delete&id={{id}}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-trash"></i> Delete</a>
                        </td>
                    </tr>
                    {{/categories}}
                </tbody>
            </table>
            {{/has_categories}}
            {{^has_categories}}
            <div class="alert alert-warning">No categories defined yet. Click "Add Category" to create one.</div>
            {{/has_categories}}
        </section>
        {{/tab_categories}}

        {{! Assignments Tab }}
        {{#tab_assignments}}
        <section class="admin-section">
            <h2 class="section-title">Assignment Management</h2>

            {{! Subtabs for assignments }}
            <ul class="nav nav-tabs mt-4" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#res-assigns-tab" type="button">Resource Assignments</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#res-categories-tab" type="button">Resource Categories</button>
                </li>
            </ul>

            <div class="tab-content mt-3">
                {{! Resource Assignments }}
                <div class="tab-pane fade show active" id="res-assigns-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Resource Assignments (Resource → Class → Section)</h4>
                        <a href="admin_res_assigns.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Assignment</a>
                    </div>
                    <div class="alert alert-info">
                        <p>Resource assignments link educational resources to specific classes and sections (for A-Level).</p>
                    </div>
                </div>

                {{! Resource Categories }}
                <div class="tab-pane fade" id="res-categories-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Resource Categories (Resource → Category)</h4>
                        <a href="admin_res_categories.php?action=add" class="btn btn-primary"><i class="fa fa-plus"></i> Add Resource Category</a>
                    </div>
                    <div class="alert alert-info">
                        <p>Link resources to categories for better organization and filtering.</p>
                    </div>
                </div>
            </div>
        </section>
        {{/tab_assignments}}
    </main>
</div>
