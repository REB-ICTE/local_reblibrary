{{!
    @template local_reblibrary/navigation

    REB Library sidebar navigation template.

    This template displays the left sidebar navigation for the library.

    Example context (json):
    {
        "browse_items": [...],
        "your_books_items": [...],
        "shelves_items": [...]
    }
}}

<div class="reblibrary-sidebar">
    {{! Browse Section }}
    <div class="sidebar-section">
        <h6 class="sidebar-heading">{{browse_heading}}</h6>
        <ul class="sidebar-menu">
            {{#browse_items}}
            <li class="sidebar-item {{#active}}active{{/active}}">
                <i class="{{icon}}"></i>
                <a href="{{url}}">{{name}}</a>
            </li>
            {{/browse_items}}
        </ul>
    </div>

    {{! Your Books Section }}
    <div class="sidebar-section">
        <h6 class="sidebar-heading">{{your_books_heading}}</h6>
        <ul class="sidebar-menu">
            {{#your_books_items}}
            <li class="sidebar-item {{#active}}active{{/active}}">
                <i class="{{icon}}"></i>
                <a href="{{url}}">{{name}}</a>
            </li>
            {{/your_books_items}}
        </ul>
    </div>

    {{! Shelves Section }}
    <div class="sidebar-section">
        <h6 class="sidebar-heading">{{shelves_heading}}</h6>
        <ul class="sidebar-menu">
            {{#shelves_items}}
            <li class="sidebar-item {{#active}}active{{/active}}">
                <i class="{{icon}}"></i>
                <a href="{{url}}">{{name}}</a>
            </li>
            {{/shelves_items}}
        </ul>
        <button class="btn btn-create-shelf">......{{create_shelf_text}}</button>
    </div>
</div>
