							<div class="skeleton-bar" style="width: 70%; height: 14px;"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- Friends Sidebar Skeleton -->
			<aside style="width: 220px; background: white; border-left: 1px solid #e5e7eb; padding: 24px 16px;">
				<div class="skeleton-bar" style="width: 100px; height: 12px; margin-bottom: 16px;"></div>
				<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
					<div class="skeleton-bar" style="width: 40px; height: 40px; border-radius: 50%;"></div>
					<div style="flex: 1;">
						<div class="skeleton-bar" style="width: 90%; height: 14px; margin-bottom: 4px;"></div>
						<div class="skeleton-bar" style="width: 70%; height: 12px;"></div>
