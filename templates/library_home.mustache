				<div style="margin-bottom: 48px;">
					<div class="skeleton-bar" style="width: 180px; height: 28px; margin-bottom: 24px;"></div>
					<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 24px;">
						<!-- Book Card Skeletons -->
						<div style="display: flex; flex-direction: column;">
							<div class="skeleton-bar" style="width: 100%; height: 200px; border-radius: 8px; margin-bottom: 12px;"></div>
							<div class="skeleton-bar" style="width: 90%; height: 16px; margin-bottom: 6px;"></div>
