				</div>
				<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
					<div class="skeleton-bar" style="width: 40px; height: 40px; border-radius: 50%;"></div>
					<div style="flex: 1;">
						<div class="skeleton-bar" style="width: 85%; height: 14px; margin-bottom: 4px;"></div>
