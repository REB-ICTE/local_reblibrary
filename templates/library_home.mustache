					<div class="skeleton-bar" style="width: 100%; height: 32px; margin-bottom: 12px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 36px; border-radius: 6px;"></div>
				</div>
			</aside>

