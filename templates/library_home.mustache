{{!
    @template local_reblibrary/library_home

    REB Library home page template.

    This template displays the library homepage with a welcome section
    and placeholder content blocks.

    Example context (json):
    {
        "welcome_message": "Welcome to REB Library",
        "description": "Browse and explore educational resources.",
        "placeholder_title": "Coming Soon",
        "placeholder_text": "Library features are currently under development."
    }
}}

<div class="local-reblibrary-home">
    {{! Hero section with welcome message }}
    <div class="container-fluid mb-4">
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info" role="alert">
                    <h4 class="alert-heading">{{welcome_message}}</h4>
                    <p class="mb-0">{{description}}</p>
                </div>
            </div>
        </div>
    </div>

    {{! Main content area }}
    <div class="container">
        <div class="row">
            {{! Placeholder content card }}
            <div class="col-md-12 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">{{placeholder_title}}</h5>
                        <p class="card-text">{{placeholder_text}}</p>
                    </div>
                </div>
            </div>
        </div>

        {{! Additional placeholder cards in a grid }}
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Browse Resources</h5>
                        <p class="card-text">Access a wide range of educational materials and learning resources.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Search Library</h5>
                        <p class="card-text">Find specific content quickly using our advanced search functionality.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">My Collection</h5>
                        <p class="card-text">Organize and access your saved resources and bookmarks.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
