<main id="library-home-root" class="local-reblibrary-library-home"
      data-resources='{{{resources_json}}}'
      data-levels='{{{levels_json}}}'
      data-sublevels='{{{sublevels_json}}}'
      data-classes='{{{classes_json}}}'
      data-categories='{{{categories_json}}}'>
	<div class="loading-skeleton" style="display: flex; flex-direction: column; min-height: 100vh; background: #f9fafb;">
		<!-- Header Skeleton -->
		<header style="background: white; border-bottom: 1px solid #e5e7eb; padding: 16px 24px;">
			<div style="display: flex; align-items: center; justify-content: space-between; max-width: 1400px; margin: 0 auto;">
				<div class="skeleton-bar" style="width: 120px; height: 32px;"></div>
				<div class="skeleton-bar" style="width: 400px; height: 40px; border-radius: 8px;"></div>
				<div style="display: flex; gap: 12px; align-items: center;">
					<div class="skeleton-bar" style="width: 100px; height: 36px; border-radius: 6px;"></div>
					<div class="skeleton-bar" style="width: 40px; height: 40px; border-radius: 50%;"></div>
					<div class="skeleton-bar" style="width: 24px; height: 24px;"></div>
					<div class="skeleton-bar" style="width: 24px; height: 24px;"></div>
				</div>
			</div>
		</header>

		<!-- Main Content Skeleton -->
		<div style="display: flex; flex: 1; max-width: 1400px; width: 100%; margin: 0 auto;">
			<!-- Sidebar Skeleton -->
			<aside style="width: 200px; background: white; border-right: 1px solid #e5e7eb; padding: 24px 16px;">
				<!-- Browse Section -->
				<div style="margin-bottom: 32px;">
					<div class="skeleton-bar" style="width: 80px; height: 12px; margin-bottom: 16px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; border-radius: 4px;"></div>
				</div>
				<!-- Your Books Section -->
				<div style="margin-bottom: 32px;">
					<div class="skeleton-bar" style="width: 90px; height: 12px; margin-bottom: 16px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; margin-bottom: 8px; border-radius: 4px;"></div>
					<div class="skeleton-bar" style="width: 100%; height: 32px; border-radius: 4px;"></div>
				</div>
				<!-- Shelves Section -->
